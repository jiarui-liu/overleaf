# === OpenAI API Key ===
OPENAI_API_KEY=sk-...

# === AI Tutor Behavior Flags ===
AI_TUTOR_LOG_PROMPTS=false
AI_TUTOR_STRICT_MODE=true
AI_TUTOR_SHOW_PREFIX=false
AI_TUTOR_DISABLED_AGENTS=latex_formatting
AI_TUTOR_SKIP_ANONYMITY=true
AI_TUTOR_SKIP_SOURCE_COMMENTS=true
AI_TUTOR_CONTENT_FOCUS=true
AI_TUTOR_RUN_BASELINE=false
# AI_TUTOR_FUZZY_THRESHOLD=0.85

# === Annotator Accounts ===
AI_TUTOR_ANNOTATION_EMAILS=annotator00@example.com,annotator01@example.com,...,annotator20@example.com
AI_TUTOR_ANNOTATOR_PASSWORDS=password0,password1,...,password20

# === Per-Annotator Paper Assignments (SHA1 hashes, semicolon-separated) ===
AI_TUTOR_ANNOTATOR_00_PAPERS=<sha1_hash>
AI_TUTOR_ANNOTATOR_01_PAPERS=<sha1_hash1>;<sha1_hash2>
# ... through AI_TUTOR_ANNOTATOR_20_PAPERS
